{
	"name": "@lagomkit/limiter",
	"version": "1.3.1",
	"type": "module",
	"keywords": [
		"limiter",
		"rate-limit",
		"throttling",
		"typescript",
		"lagomkit"
	],
	"author": "Chirill Ceban <cc@bitkidd.dev>",
	"license": "MIT",
	"description": "Typed rate-limiting toolkit with composable drivers and a lightweight service factory.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitkidd/lagomkit.git"
	},
	"main": "./dist/src/exports.js",
	"types": "./dist/src/exports.d.ts",
	"sideEffects": false,
	"directories": {
		"test": "tests"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"prepare": "npm run build",
		"prepublishOnly": "npm run test",
		"build": "rm -rf dist/* && tsgo --project tsconfig.build.json",
		"check": "pnpx @biomejs/biome check --write",
		"format": "pnpx @biomejs/biome format --write",
		"lint": "pnpx @biomejs/biome lint --write",
		"typecheck": "tsgo --noEmit",
		"test": "vitest run --sequence.concurrent",
		"coverage": "vitest run --coverage"
	},
	"files": [
		"/dist/"
	],
	"exports": {
		".": {
			"types": "./dist/src/exports.d.ts",
			"import": "./dist/src/exports.js",
			"default": "./dist/src/exports.js"
		},
		"./service": {
			"types": "./dist/src/service.d.ts",
			"import": "./dist/src/service.js",
			"default": "./dist/src/service.js"
		},
		"./types": {
			"types": "./dist/src/types.d.ts",
			"import": "./dist/src/types.js",
			"default": "./dist/src/types.js"
		},
		"./drivers/*": {
			"types": "./dist/src/drivers/*.d.ts",
			"import": "./dist/src/drivers/*.js",
			"default": "./dist/src/drivers/*.js"
		}
	},
	"dependencies": {
		"rate-limiter-flexible": "^10.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260227.1"
	}
}
